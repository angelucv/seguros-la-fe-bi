# Copiar a variables en Railway (Settings → Variables) o a .env local (no subir .env al repo)

# Producción: el script `npm start` ya fuerza NODE_ENV=production
# NODE_ENV=production

# Puerto: Railway inyecta PORT automáticamente
# PORT=3000

# Carpeta con los CSV (primas, BCV, etc.). En Railway suele ser un volumen montado.
# Si no se define, el servidor usa ./data/public respecto al cwd.
# DATA_DIR=/data/public
