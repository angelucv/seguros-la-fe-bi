{
  "name": "seguros-la-fe-bi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/predev.mjs",
    "dev": "tsx watch server.ts",
    "dev:3010": "node scripts/predev.mjs && cross-env PORT=3010 tsx watch server.ts",
    "dev:win:fresh": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/win-kill-3000.ps1 && npm run dev",
    "doctor": "node scripts/doctor.mjs",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "preview": "vite preview",
    "lint": "npx tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "data:download": "npm run download --prefix etl",
    "data:transform": "npm run transform --prefix etl && npm run data:sync",
    "data:all": "npm run all --prefix etl && npm run data:sync",
    "data:sync": "node scripts/sync-data-from-etl.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.546.0",
    "plotly.js-dist-min": "^3.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/plotly.js": "^3.0.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vitest": "^4.1.4"
  }
}
